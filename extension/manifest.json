{
  "manifest_version": 3,
  "name": "WSVPN Proxy",
  "version": "1.0",
  "description": "Smart routing through WSVPN — bypass specified regions and custom CIDR ranges.",
  "permissions": [
    "proxy",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WSVPN"
  },
  "icons": {
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
